{
  "name": "forgemind",
  "version": "1.0.0",
  "description": "Autonomous AI Developer System - Devin alternative built on Claude Code + Ruflo",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "start:monitor": "node dist/index.js --daemon",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "swarm:init": "npx ruflo swarm init --topology hierarchical --config ruflo-workflow.json",
    "swarm:start": "npx ruflo hive-mind spawn FORGEMIND --config ruflo-workflow.json",
    "swarm:status": "npx ruflo status --watch",
    "swarm:stop": "npx ruflo daemon stop",
    "logs:success": "node scripts/cost-report.js --stream=success",
    "logs:fail": "node scripts/cost-report.js --stream=fail",
    "logs:rollback": "node scripts/cost-report.js --stream=rollback",
    "logs:cost": "node scripts/cost-report.js --period=today",
    "health": "node scripts/health-check.js",
    "seed": "node scripts/seed-agentdb.js",
    "migrate": "npx prisma migrate deploy",
    "generate": "npx prisma generate",
    "docker:dev": "docker-compose up --build",
    "docker:prod": "docker-compose -f docker/docker-compose.prod.yml up -d"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@prisma/client": "^5.20.0",
    "@slack/bolt": "^3.22.0",
    "@slack/web-api": "^7.11.0",
    "axios": "^1.8.4",
    "docx": "^8.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "handlebars": "^4.7.8",
    "ioredis": "^5.5.0",
    "js-yaml": "^4.1.0",
    "marked": "^13.0.3",
    "node-cron": "^3.0.3",
    "p-queue": "^8.1.0",
    "p-retry": "^6.2.1",
    "prisma": "^5.20.0",
    "semver": "^7.7.1",
    "simple-git": "^3.27.0",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.24",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  },
  "optionalDependencies": {
    "hnswlib-node": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/agents/BAInterpreterAgent.ts",
      "src/agents/ArchitectAgent.ts",
      "src/agents/CoderAgent.ts",
      "src/gates/ApprovalGate.ts",
      "src/swarm/AgentDB.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "json-summary"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 45,
        "functions": 80,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
