# --- AI Provider ---
AI_PROVIDER=anthropic

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# --- Models ---
FORGEMIND_MODEL_BA_INTERPRETER=claude-sonnet-4-6
FORGEMIND_MODEL_ARCHITECT=claude-opus-4-6
FORGEMIND_MODEL_CODER=claude-sonnet-4-6
FORGEMIND_MODEL_TESTER=claude-sonnet-4-6
FORGEMIND_MODEL_REVIEWER=claude-sonnet-4-6
FORGEMIND_MODEL_REVIEWER_QUALITY=claude-sonnet-4-6
FORGEMIND_MODEL_REVIEWER_SECURITY=claude-sonnet-4-6
FORGEMIND_MODEL_REVIEWER_PERFORMANCE=claude-sonnet-4-6
FORGEMIND_MODEL_DEBUGGER=claude-sonnet-4-6
FORGEMIND_MODEL_ROLLBACK=claude-haiku-4-5-20251001
FORGEMIND_MODEL_DEVOPS=claude-haiku-4-5-20251001
FORGEMIND_MODEL_MONITOR=claude-haiku-4-5-20251001
FORGEMIND_MODEL_DEFAULT_ANTHROPIC=claude-sonnet-4-6
FORGEMIND_MODEL_DEFAULT_GEMINI=gemini-2.5-flash
FORGEMIND_MODEL_DEFAULT=

# --- GitHub ---
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo
GITHUB_DEFAULT_BRANCH=main
GITHUB_REVIEWERS=tech-lead,senior-dev

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...
SLACK_CHANNEL=#ai-dev-requests
SLACK_ALERTS_CHANNEL=#dev-alerts
SLACK_PR_CHANNEL=#dev-prs

# --- Google Chat (optional) ---
GOOGLE_CHAT_PROJECT_ID=your-gcp-project
GOOGLE_CHAT_SPACE_ID=spaces/XXXXXX
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
GOOGLE_CHAT_WEBHOOK_URL=

# --- Ruflo ---
RUFLO_LICENSE_KEY=...
RUFLO_WEBHOOK_SECRET=...
RUFLO_MAX_CONCURRENT_TASKS=3

# --- FORGEMIND ---
FORGEMIND_WEBHOOK_URL=https://your-server.com/webhooks
FORGEMIND_ENV=development
FORGEMIND_LOG_LEVEL=info
FORGEMIND_TASK_TIMEOUT_MS=3600000
FORGEMIND_MAX_COST_PER_TASK_USD=5.00
FORGEMIND_GATE_TIMEOUT_MS=86400000
FORGEMIND_GATE_POLL_MS=5000
FORGEMIND_TEST_COMMAND=npm.cmd test -- --passWithNoTests

# --- Cost Tracking ---
COST_ALERT_THRESHOLD_USD=3.00
COST_DAILY_LIMIT_USD=100.00

# --- Monitoring ---
MONITOR_ENABLED=true
MONITOR_CHECK_INTERVAL_MS=30000
MONITOR_P0_ERROR_RATE_THRESHOLD=0.5
MONITOR_P1_ERROR_RATE_THRESHOLD=0.1
MONITOR_APM_URL=

# --- Database ---
DATABASE_URL=file:./forgemind.db

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Security ---
WEBHOOK_SECRET=...
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
